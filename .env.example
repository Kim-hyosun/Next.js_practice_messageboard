# MongoDB
MONGOKEY=mongodb+srv://<user>:<password>@<cluster>/?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-string
# (legacy alias, kept for backward compat)
myJWTsecret=replace-with-random-string

# GitHub OAuth
githubAuthId=
githubAuthPw=

# AWS S3 (presigned upload)
s3_ACCESS_KEY=
s3_SECRET_KEY=
s3_myBucketName=
